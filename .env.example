# Flow Agent Telemetry v2
# Copy this to .env and fill in your values

# --- Core ---
NODE_ENV=development
LOG_LEVEL=info

# --- Encrypted DB ---
# SQLCipher key for ~/.flow-agent/context.db
# Generate with: openssl rand -base64 32
FLOW_DB_KEY=

# --- Sensors ---
# Polling interval in ms for active-win
ACTIVE_WIN_POLL_MS=2000

# Enable/disable sensors
ENABLE_APP_SENSOR=true
ENABLE_IDE_SENSOR=true

# --- Rule Engine ---
# How often to evaluate rules in ms
RULE_INTERVAL_MS=30000

# Stuck rule: minutes of IDE focus with no keystrokes before firing
STUCK_RULE_MINUTES=5

# --- Servers ---
# MCP Server-Sent Events port
MCP_PORT=8000

# WebSocket port for UI/LLM interventions
WS_PORT=8001

# --- IDE IPC ---
IDE_SOCKET_PATH=/tmp/flow-agent-ide.sock

# --- Optional: LLM Integration ---
# Used if you send interventions to OpenAI/Claude/etc
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: Notifications ---
# macOS notification webhook or local path
NOTIFICATION_SOUND_PATH=