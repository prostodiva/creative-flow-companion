{
  "name": "flow-agent-telemetry",
  "version": "2.0.0",
  "description": "Local-first activity telemetry daemon for proactive LLM agent",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --import=tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "5.3.1",
    "active-win": "5.1.3",
    "chokidar": "3.6.0",
    "dotenv": "16.4.5",
    "fastmcp": "1.20.5",
    "glob": "10.4.2",
    "node-notifier": "10.0.1",
    "pino": "9.1.0",
    "prom-client": "15.1.3",
    "ws": "8.17.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.14.2",
    "@types/node-notifier": "8.0.5",
    "@types/ws": "8.5.10",
    "pino-pretty": "^13.1.3",
    "tsx": "4.15.7",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
