{
  "name": "flow-agent-telemetry",
  "version": "2.0.0",
  "description": "Local-first activity telemetry daemon for proactive LLM agent",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && node scripts/copy-db-assets.mjs",
    "dev": "node --import=tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@journeyapps/sqlcipher": "5.3.1",
    "@langchain/community": "^0.3.45",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/ollama": "^0.2.3",
    "active-win": "5.1.3",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.6.2",
    "chokidar": "3.6.0",
    "chromadb": "^3.4.3",
    "dotenv": "16.4.5",
    "fastmcp": "1.20.5",
    "glob": "10.4.2",
    "node-cron": "^4.2.1",
    "node-notifier": "10.0.1",
    "pino": "9.1.0",
    "prettier": "^3.8.3",
    "prom-client": "15.1.3",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "20.14.2",
    "@types/node-notifier": "8.0.5",
    "@types/ws": "8.5.10",
    "pino-pretty": "^13.1.3",
    "tsx": "4.15.7",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
